# Configuração da Microsoft Graph para a skill agenda-brp.
# Copie este arquivo para "graph.env" na máquina da automação e preencha o segredo.
# NÃO comite o graph.env preenchido (ele contém o segredo, que é como uma senha).

# App registration "AJM-BRP-Automacao" (não são segredos — IDs públicos)
GRAPH_TENANT_ID=c650c126-afeb-459a-8af1-cc57d1be4a23
GRAPH_CLIENT_ID=7764b636-359f-42dd-8be4-a45550f072c2

# Segredo do cliente (passo 3 do registro) — o "Valor", não o "ID do segredo".
# Mantenha em variável de ambiente / cofre. Deixe vazio aqui no exemplo.
GRAPH_CLIENT_SECRET=

# Caixa que hospeda o calendário "BRP" (precisa existir e estar compartilhado).
# Para teste, pode ser a própria conta de teste.
BRP_MAILBOX=
